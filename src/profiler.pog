    glGetQueryObject pname:
        GL_QUERY_RESULT
        GL_QUERY_RESULT_NO_WAIT​
        GL_QUERY_RESULT_AVAILABLE

    void glGetQueryiv(GLenum target, GLenum pname, GLint* params);
    void glGetQueryIndexediv(GLenum target, GLuint index, GLenum pname, GLint* params);

    void glGenQueries(GLsizei n, GLuint* ids);
    void glDeleteQueries(GLsizei n, const GLuint* ids);
    GLboolean glIsQuery(GLuint id);

    void glObjectLabel(GL_QUERY, GLuint name, GLsizei length, const GLchar* label);

    void glGetQueryObjectui64v(GLuint id, GLenum pname, GLuint64* params);
    void glGetQueryObjecti64v(GLuint id, GLenum pname, GLint64* params);
    void glGetQueryObjectuiv(GLuint id, GLenum pname, GLuint* params);
    void glGetQueryObjectiv(GLuint id, GLenum pname, GLint* params);

    void glQueryCounter(GLuint id, GLenum target);

    void glBeginQuery(GLenum target, GLuint id);
    void glBeginQueryIndexed(GLenum target, GLuint index, GLuint id);
    void glEndQuery(GLenum target);
    void glEndQueryIndexed(GLenum target, GLuint index);

    void glGetQueryBufferObjectuiv  (GLuint id, GLuint buffer, GLenum pname, GLintptr offset);
    void glGetQueryBufferObjectui64v(GLuint id, GLuint buffer, GLenum pname, GLintptr offset);
    void glGetQueryBufferObjecti64v (GLuint id, GLuint buffer, GLenum pname, GLintptr offset);
    void glGetQueryBufferObjectiv   (GLuint id, GLuint buffer, GLenum pname, GLintptr offset);

*/


uint32 ogl_query_current(GLenum target) {
    uint32 params = 0;
    glGetQueryiv(target, GL_CURRENT_QUERY, *params);
    return params;
}

int32 ogl_query_bits(GLenum target) {
    int32 params = 0;
    glGetQueryiv(target, GL_QUERY_COUNTER_BITS, *params);
    return params;
}


bool ogl_query_result_available(GLuint id) {
    GLuint params = GL_FALSE;
    glGetQueryObjectuiv(id, GL_QUERY_RESULT_AVAILABLE, *params);
    return params == GL_TRUE;
}

uint64 ogl_query_result_nowait(GLuint id) {
    GLuint64 params = 0;
    glGetQueryObjectui64v(id, GL_QUERY_RESULT_NO_WAIT​, *params);
    return params;
}

uint64 ogl_query_result(GLuint id) {
    GLuint64 params = 0;
    glGetQueryObjectui64v(id, GL_QUERY_RESULT, *params);
    return params;
}


