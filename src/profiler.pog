struct Frame_GPU_Timestamp {

}

struct Frame_Timestamps {
    GLuint* queries;
    uint32 query_count;

    uint32 timestamp_count;
}

Frame_Timestamps frame_timestamps = {};

void ogl_query_timestamp(uint32* q) {
    if !glIsQuery(@q) {
        glGenQueries(1, q);
    }

    glQueryCounter(id, GL_TIMESTAMP);
}

void ogl_query_timestamp(char* label) {

    if fts.timestamp_count == fts.query_count {
        fts.query_count += 1;
        fts.queries = realloc(fts.query_count * sizeof GLuint);
        glGenQueries(1, fts.queries + fts.timestamp_count);
    }

    GLuint id = fts.queries[fts.timestamp_count++];
    GLsizei length = -1; // null-terminated
    glObjectLabel(GL_QUERY, id, length, label);
    glQueryCounter(id, GL_TIMESTAMP);
}



void measure_frametime() {
    UI_Rect rect_total;

    const sample_count = 60*3;
    static float32* samples = calloc(1, sample_count * sizeof float32);
    static uint32 sample_index = 0;

    samples[sample_index++ % sample_count] = app.frame_time as float32;

    float32 dt_min = 99999999999999999999.0;
    float32 dt_max = 0;
    float32 dt_avg = 0;

    for 0 .. sample_count {
        let dt = samples[it];
        dt_min = min(dt_min, dt);
        dt_max = max(dt_max, dt);
        dt_avg += dt;
    }

    dt_avg /= sample_count;

    // rect_total.size.x

    float32 column_width = 2.0 / sample_count;
    for 0 .. sample_count {
        let dt = samples[it];
        vec2 size = { column_width, dt / (3.0*dt_avg) };
        vec2 pos = make_vec(column_width/2 + size.x * it - 1, size.y/2.0 - 1);
        draw_rect(pos, size, opacity(White, 0.3));
    }

    void dl(float32 dt, dt_avg, Color color) {
        let micro_sec = round(dt * 1000_000) as uint64;
        vec2 size = { 2, 0.005 };
        vec2 pos  = { 0, dt / (3.0*dt_avg) - 1 };
        draw_rect(pos, size, color);
        const text_height = 0.05;
        draw_text(pos + make_vec(1 + text_height/2.0, 0), text_height, to_string(micro_sec), color);
    }

    dl(dt_max, dt_avg, Red);
    dl(dt_min, dt_avg, Blue);
    dl(dt_avg, dt_avg, Green);
    // dl(app.frame_time as float32, dt_avg, Yellow);
}

