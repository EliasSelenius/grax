

struct Shader_Manager {
    Shader*[..] shaders;
    Shader* active_shader;

    UBO*[..]  uniform_buffers;
    SSBO*[..] storage_buffers;

}

Shader_Manager shader_manager;


Shader* alloc_shader() {
    Shader* shader = calloc(sizeof Shader, 1);

    if shader_manager.shaders == null {
        shader_manager.shaders = list_create(sizeof Shader*);
    }

    list_add(*shader_manager.shaders, *shader);
    return shader;
}

Shader* alloc_shader(char* filename) {
    let sh = alloc_shader();
    sh.name = make_string(filename);
    return sh;
}

Shader load_shader(char* filename) {
    Shader program = {};
    program.name = make_string(filename); // TODO: we dont know the ownership of filename
    shader_init(*program);
    return program;
}

enum Shaderstages {
    Vertex      = 0b000001;
    TessControl = 0b000010;
    TessEval    = 0b000100;
    Geometry    = 0b001000;
    Fragment    = 0b010000;
    Compute     = 0b100000;
}

struct UBO {
    string name;
    uint32 binding_point;
    uint32 buffer_id;
}

struct SSBO {
    string name;
    uint32 binding_point;
    uint32 buffer_id;
}

void update_ssbo(char* name, void* data, uint32 size) {
    let ssbo = get_ssbo(name);

    if ssbo.buffer_id == 0 {
        uint32 buffer_id = ogl_buffer_generate(name);
        bind_ssbo_buffer(ssbo, buffer_id);
    }

    ogl_buffer_init(ssbo.buffer_id, size, data);
}

void update_ssbo(char* name, void[..] list) {
    update_ssbo(name, list as void*, list_length(list) * list_stride(list));
}

UBO* get_ubo(char* name) { return get_ubo(make_string(name)); }
UBO* get_ubo(string name) {
    if shader_manager.uniform_buffers == null {
        shader_manager.uniform_buffers = list_create(sizeof UBO*);
    }

    uint32 len = list_length(shader_manager.uniform_buffers);
    for 0 .. len {
        UBO* ubo = shader_manager.uniform_buffers[it];
        if string_equals(name, ubo.name) return ubo;
    }

    UBO* ubo = malloc(sizeof UBO);
    @ubo = {};
    ubo.binding_point = len;
    ubo.name = alloc_string_copy(name);

    // TODO: this is retarded...
    uint32 buffer_id = ogl_buffer_generate(ubo.name);
    bind_buffer(ubo, buffer_id);

    list_add(*shader_manager.uniform_buffers, *ubo);
    return ubo;
}

SSBO* get_ssbo(char* name) return get_ssbo(make_string(name));
SSBO* get_ssbo(string name) {
    if shader_manager.storage_buffers == null {
        shader_manager.storage_buffers = list_create(sizeof SSBO*);
    }

    uint32 len = list_length(shader_manager.storage_buffers);
    for 0 .. len {
        SSBO* ssbo = shader_manager.storage_buffers[it];
        if string_equals(name, ssbo.name) return ssbo;
    }

    SSBO* ssbo = malloc(sizeof SSBO);
    @ssbo = {};
    ssbo.binding_point = len;
    ssbo.name = alloc_string_copy(name);
    list_add(*shader_manager.storage_buffers, *ssbo);
    return ssbo;
}

void bind_ssbo_buffer(SSBO* ssbo, uint32 buffer_id) {
    GLenum target = GL_SHADER_STORAGE_BUFFER;
    glBindBufferBase(target, ssbo.binding_point, buffer_id);
    ssbo.buffer_id = buffer_id;
}

void bind_buffer(UBO* ubo, uint32 buffer_id) {
    GLenum target = GL_UNIFORM_BUFFER;
    glBindBufferBase(target, ubo.binding_point, buffer_id);
    ubo.buffer_id = buffer_id;
}

struct Shader {
    Arena* arena;

    string name;
    uint32 gl_handle;

    string log_program;
    string log_vertex;
    string log_tess_control;
    string log_tess_eval;
    string log_geometry;
    string log_fragment;
    string log_compute;

    Shaderstages stages;

    Shader_Uniform[]       uniforms;
    Shader_Uniform_Block[] uniform_blocks;
    Shader_Storage_Block[] storage_blocks;

    // TODO: implement introspection: https://www.khronos.org/opengl/wiki/Program_Introspection#Interface_query
    // TODO: glValidateProgram might produce some insightfull info
}

void use(Shader* s) {
    if s.gl_handle == 0 {
        shader_init(s);
    }

    shader_manager.active_shader = s;
    glUseProgram(s.gl_handle);
}

void dispatch_compute(uint32 x, y, z) {
    glDispatchCompute(x, y, z);
}

void dispatch_compute(ivec3 size) {
    glDispatchCompute(size.x, size.y, size.z);
}

void shader_bind_buffers(Shader* shader) {
    for 0 .. shader.storage_blocks.length {
        let info = shader.storage_blocks[it];
        let ssbo = get_ssbo(info.name);
        glShaderStorageBlockBinding(shader.gl_handle, it, ssbo.binding_point);
    }

    for 0 .. shader.uniform_blocks.length {
        let info = shader.uniform_blocks[it];
        let ubo  = get_ubo(info.name);
        glUniformBlockBinding(shader.gl_handle, it, ubo.binding_point);
    }
}

