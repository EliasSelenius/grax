void draw_ui_shader() {
    static int32 shader_index = 0;

    uint32 shader_count = list_length(shader_manager.shaders);

    if key_down(Key.left_control) {
        if key_pressed(Key.page_up) {
            shader_index = (shader_count+shader_index+1) % shader_count;
        } else if key_pressed(Key.page_down) {
            shader_index = (shader_count+shader_index-1) % shader_count;
        }
    }

    Shader* shader = shader_manager.shaders[shader_index];

    float text_size = 0.035;
    Color color_text = LightGray;

    UI_Rect rect_window = rect_pp(app.bottom_left, app.top_right);

    draw_text(rect_window, -1, 1, text_size*2.0, shader.name, color_text);


    float left = app.left + text_size;
    vec2 start_cursor = {left, 0.5};
    vec2 cursor = start_cursor;
    float extent = start_cursor.x;

    uint32 uniform_count = 0;

    for 0 .. shader.uniforms.length {
        Shader_Uniform* uni = *shader.uniforms[it];
        if uni.block_index != -1  continue;
        uniform_count++;

        glsl_Type glsl_type = uni.ogl_type as glsl_Type;

        cursor = draw_text(cursor, text_size, "location:", color_text);
        cursor = draw_text(cursor, text_size, to_string(uni.location), color_text);
        cursor.x += text_size*0.5;

        char* type_name = glsl_type_name(glsl_type);
        cursor = draw_text(cursor, text_size, type_name, Purple);
        cursor = draw_text(cursor, text_size, " ", color_text);
        cursor = draw_text(cursor, text_size, uni.name,  color_text);

        void* value = get_uniform(shader, uni.location, glsl_type);
        string value_str = glsl_value_string(glsl_type, value);

        cursor = draw_text(cursor, text_size, " = ", color_text);
        cursor = draw_text(cursor, text_size, value_str, White);

        let sb = temp_builder();
        if uni.array_size != -1                   {sb_append(sb, " array_size:");                  sb_append(sb, uni.array_size);}
        if uni.offset != -1                       {sb_append(sb, " offset:");                      sb_append(sb, uni.offset);}
        if uni.block_index != -1                  {sb_append(sb, " block_index:");                 sb_append(sb, uni.block_index);}
        if uni.array_stride != -1                 {sb_append(sb, " array_stride:");                sb_append(sb, uni.array_stride);}
        if uni.matrix_stride != -1                {sb_append(sb, " matrix_stride:");               sb_append(sb, uni.matrix_stride);}
        if uni.atomic_counter_buffer_index != -1  {sb_append(sb, " atomic_counter_buffer_index:"); sb_append(sb, uni.atomic_counter_buffer_index);}
        // if uni.location != -1                     {sb_append(sb, " location:");                    sb_append(sb, uni.location);}

        cursor = draw_text(cursor, text_size, to_string(sb), color_text);
        cursor = draw_text(cursor, text_size, "\n", color_text);

        extent = max(cursor.x, extent);
        cursor.x = left;
    }

    vec2 ofs = {-text_size*0.5, text_size}*0.5;
    UI_Rect rect_bkg = rect_pp(start_cursor + ofs, make_vec(extent, cursor.y) + ofs);
    draw_rect(rect_bkg, opacity(Black, 0.4));
}

Shaderstages process_glsl_source(StringBuilder* sb, char* filename) {
    char* src = fileread(filename);

    Shaderstages stages = 0;

    sb_append(sb, "#line 1\n");

    char* buffer = src;
    uint32 line_num = 1;
    while @buffer {
        let line = substr_until(buffer, '\n');
        bool omit_line = false;

        if starts_with(line.chars, "#include \"") {
            char* fn = buffer + 10;
            let len = substr_until(fn, '"').length - 1;
            fn[len] = 0 as char;

            stages |= process_glsl_source(sb, fn);

            sb_append(sb, "\n#line ");
            sb_append(sb, to_string(line_num + 1));
            sb_append(sb, "\n");

            omit_line = true;

        } else if starts_with(line.chars, "#ifdef VertexShader") {
            stages |= .Vertex;
        } else if starts_with(line.chars, "#ifdef TessControl") {
            stages |= .TessControl;
        } else if starts_with(line.chars, "#ifdef TessEval") {
            stages |= .TessEval;
        } else if starts_with(line.chars, "#ifdef GeometryShader") {
            stages |= .Geometry;
        } else if starts_with(line.chars, "#ifdef FragmentShader") {
            stages |= .Fragment;
        } else if starts_with(line.chars, "#ifdef Compute") {
            stages |= .Compute;
        }


        if !omit_line {
            sb_append(sb, line);
        }


        line_num++;
        buffer += line.length;
    }

    free(src);

    return stages;
}

void shader_init(Shader* program) {
    char* get_shader_source(char* def_IO, shader_type, src) {
        let sb = temp_builder();
        // NOTE: layout(binding) requires "#version 420" or later
        // NOTE: ssbo requires "#version 430 core"
        char* glsl_version = "#version 430 core\n";
        sb_append(sb, glsl_version);
        sb_append(sb, "#define IO ");
        if def_IO sb_append(sb, def_IO);
        sb_append(sb, "\n");
        sb_append(sb, "#define ");
        sb_append(sb, shader_type);
        sb_append(sb, "\n");
        sb_append(sb, src);

        return sb.content;
    }

    uint32 make_shader(Shader* program, GLenum _type, string* log, char* code) {
        if code == null return 0;

        char* get_shader_type_string(GLenum shader_type) {
            switch shader_type {
                case GL_COMPUTE_SHADER:         return "compute";
                case GL_VERTEX_SHADER:          return "vertex";
                case GL_TESS_CONTROL_SHADER:    return "tess_control";
                case GL_TESS_EVALUATION_SHADER: return "tess_evaluation";
                case GL_GEOMETRY_SHADER:        return "geometry";
                case GL_FRAGMENT_SHADER:        return "fragment";
            }

            return null;
        }

        uint32 shader = glCreateShader(_type);
        glShaderSource(shader, 1, *code, null); // null assumes null-terminated string
        glCompileShader(shader); // NOTE: my stinky laptop needed this

        GLint success = 0;
        glGetShaderiv(shader, GL_COMPILE_STATUS, *success);
        if success == 0 {
            let shader_type = get_shader_type_string(_type);
            print("[INFO]: ShaderProgram ", program.gl_handle, " \"", program.name, "\" ", shader_type, " shader failed to compile. info log was generated.\n");
        }

        update_shader_stage_info_log(shader, log);

        glAttachShader(program.gl_handle, shader);
        return shader;
    }

    StringBuilder src = sb_create();
    program.stages = process_glsl_source(*src, program.name.chars);

    char* vs_src = program.stages & .Vertex      ? get_shader_source("out", "VertexShader",   src.content) : null;
    char* tc_src = program.stages & .TessControl ? get_shader_source(null,  "TessControl",    src.content) : null;
    char* te_src = program.stages & .TessEval    ? get_shader_source(null,  "TessEval",       src.content) : null;
    char* gs_src = program.stages & .Geometry    ? get_shader_source(null,  "GeometryShader", src.content) : null;
    char* fs_src = program.stages & .Fragment    ? get_shader_source("in",  "FragmentShader", src.content) : null;
    char* cs_src = program.stages & .Compute     ? get_shader_source(null,  "Compute",        src.content) : null;

    sb_free(src);

    if program.arena  arena_reset(program.arena);
    else              program.arena = arena_create();

    if program.gl_handle == 0 {
        program.gl_handle = glCreateProgram();
        glObjectLabel(GL_PROGRAM, program.gl_handle, program.name.length as GLsizei, program.name.chars);
    }

    uint32 vs = make_shader(program, GL_VERTEX_SHADER,          *program.log_vertex,          vs_src);
    uint32 tc = make_shader(program, GL_TESS_CONTROL_SHADER,    *program.log_tess_control,    tc_src);
    uint32 te = make_shader(program, GL_TESS_EVALUATION_SHADER, *program.log_tess_eval,       te_src);
    uint32 gs = make_shader(program, GL_GEOMETRY_SHADER,        *program.log_geometry,        gs_src);
    uint32 fs = make_shader(program, GL_FRAGMENT_SHADER,        *program.log_fragment,        fs_src);
    uint32 cs = make_shader(program, GL_COMPUTE_SHADER,         *program.log_compute,         cs_src);

    glLinkProgram(program.gl_handle);


    void cleanup_shader(uint32 program, shader) {
        glDetachShader(program, shader);
        glDeleteShader(shader);
    }

    if vs  cleanup_shader(program.gl_handle, vs);
    if tc  cleanup_shader(program.gl_handle, tc);
    if te  cleanup_shader(program.gl_handle, te);
    if gs  cleanup_shader(program.gl_handle, gs);
    if fs  cleanup_shader(program.gl_handle, fs);
    if cs  cleanup_shader(program.gl_handle, cs);

    update_shader_program_info_log(program);


    int32 status;
    glGetProgramiv(program.gl_handle, GL_LINK_STATUS, *status);
    if status == 0 {
        print("[INFO]: ShaderProgram ", program.gl_handle, " \"", program.name, "\" failed to link.\n");
        return;
    }

    shader_introspect(program);
    shader_bind_buffers(program);

    print("[INFO]: ShaderProgram ", program.gl_handle, " \"", program.name, "\"");
    if vs_src  print(", Vertex");
    if tc_src  print(", TessControl");
    if te_src  print(", TessEval");
    if gs_src  print(", Geometry");
    if fs_src  print(", Fragment");
    if cs_src  print(", Compute");
    print("\n");
}

void shader_reload(Shader* shader) {
    shader_init(shader);
}

void delete_shader(Shader* shader) {
    glDeleteProgram(shader.gl_handle);

    if shader.log_program.chars       free(shader.log_program.chars);
    if shader.log_vertex.chars        free(shader.log_vertex.chars);
    if shader.log_tess_control.chars  free(shader.log_tess_control.chars);
    if shader.log_tess_eval.chars     free(shader.log_tess_eval.chars);
    if shader.log_geometry.chars      free(shader.log_geometry.chars);
    if shader.log_fragment.chars      free(shader.log_fragment.chars);
    if shader.log_compute.chars       free(shader.log_compute.chars);

    arena_release(shader.arena);
    shader.arena = null;
}

void update_shader_stage_info_log(uint32 shader_stage_id, string* log) {
    int32 log_length = 0;
    glGetShaderiv(shader_stage_id, GL_INFO_LOG_LENGTH, *log_length);

    if log_length {
        log.chars = realloc(log.chars, log_length);
        log.length = log_length - 1; // log_length contains zero termination

        glGetShaderInfoLog(shader_stage_id, log_length, null, log.chars);
    } else {
        if log.chars free(log.chars);
        @log = {};
    }
}

void update_shader_program_info_log(Shader* shader) {
    int32 log_length = 0;
    glGetProgramiv(shader.gl_handle, GL_INFO_LOG_LENGTH, *log_length);

    if log_length {
        shader.log_program.chars = realloc(shader.log_program.chars, log_length);
        shader.log_program.length = log_length - 1; // log_length contains zero termination

        glGetProgramInfoLog(shader.gl_handle, log_length, null, shader.log_program.chars);
    } else {
        if shader.log_program.chars free(shader.log_program.chars);
        shader.log_program = {};
    }
}

void set_uniform(char* name, int32   x)          glUniform1i (glGetUniformLocation(shader_manager.active_shader.gl_handle, name), x);
void set_uniform(char* name, int32   x, y)       glUniform2i (glGetUniformLocation(shader_manager.active_shader.gl_handle, name), x, y);
void set_uniform(char* name, int32   x, y, z)    glUniform3i (glGetUniformLocation(shader_manager.active_shader.gl_handle, name), x, y, z);
void set_uniform(char* name, int32   x, y, z, w) glUniform4i (glGetUniformLocation(shader_manager.active_shader.gl_handle, name), x, y, z, w);
void set_uniform(char* name, uint32  x)          glUniform1ui(glGetUniformLocation(shader_manager.active_shader.gl_handle, name), x);
void set_uniform(char* name, uint32  x, y)       glUniform2ui(glGetUniformLocation(shader_manager.active_shader.gl_handle, name), x, y);
void set_uniform(char* name, uint32  x, y, z)    glUniform3ui(glGetUniformLocation(shader_manager.active_shader.gl_handle, name), x, y, z);
void set_uniform(char* name, uint32  x, y, z, w) glUniform4ui(glGetUniformLocation(shader_manager.active_shader.gl_handle, name), x, y, z, w);
void set_uniform(char* name, float32 x)          glUniform1f (glGetUniformLocation(shader_manager.active_shader.gl_handle, name), x);
void set_uniform(char* name, float32 x, y)       glUniform2f (glGetUniformLocation(shader_manager.active_shader.gl_handle, name), x, y);
void set_uniform(char* name, float32 x, y, z)    glUniform3f (glGetUniformLocation(shader_manager.active_shader.gl_handle, name), x, y, z);
void set_uniform(char* name, float32 x, y, z, w) glUniform4f (glGetUniformLocation(shader_manager.active_shader.gl_handle, name), x, y, z, w);
void set_uniform(char* name, float64 x)          glUniform1d (glGetUniformLocation(shader_manager.active_shader.gl_handle, name), x);
void set_uniform(char* name, float64 x, y)       glUniform2d (glGetUniformLocation(shader_manager.active_shader.gl_handle, name), x, y);
void set_uniform(char* name, float64 x, y, z)    glUniform3d (glGetUniformLocation(shader_manager.active_shader.gl_handle, name), x, y, z);
void set_uniform(char* name, float64 x, y, z, w) glUniform4d (glGetUniformLocation(shader_manager.active_shader.gl_handle, name), x, y, z, w);

void set_uniform(char* name, vec2 v)  set_uniform(name, v.x, v.y);
void set_uniform(char* name, vec3 v)  set_uniform(name, v.x, v.y, v.z);
void set_uniform(char* name, vec4 v)  set_uniform(name, v.x, v.y, v.z, v.w);
void set_uniform(char* name, ivec2 v) set_uniform(name, v.x, v.y);
void set_uniform(char* name, ivec3 v) set_uniform(name, v.x, v.y, v.z);
void set_uniform(char* name, ivec4 v) set_uniform(name, v.x, v.y, v.z, v.w);

