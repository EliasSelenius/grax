

Vertex_Attrib_Type[] vertex3D_attribs = { .vec3, .vec3, .vec2 };
struct vertex3D {
    vec3 pos;
    vec3 normal;
    vec2 uv;
}

Vertex_Attrib_Type[] vertex2D_attribs = { .vec2, .vec2, .color };
struct vertex2D {
    vec2 pos;
    vec2 uv;
    Color color;
}



enum Mesh_Primitive {
    Triangles;
    Lines;
    LineStrip;
    LineLoop;
    Quad_Patches;
}

GLenum ogl_mode(Mesh_Primitive prim) switch prim {
    case .Triangles:    return GL_TRIANGLES;
    case .Lines:        return GL_LINES;
    case .LineStrip:    return GL_LINE_STRIP;
    case .LineLoop:     return GL_LINE_LOOP;
    case .Quad_Patches: return GL_PATCHES;
    default: return 0;
}

struct Mesh {
    vertex3D[..] vertices;
    uint32[..] indices;

    VAO* vao;
    uint32 vao_index_start;
    uint32 vao_index_count;
    uint32 vao_vertex_base;

    string name;

    Mesh_Primitive primitive;
    Poly front_face, back_face;

    vec3 bb_min, bb_max;
    float max_radius;
}

struct VAO {
    Mesh*[..] meshes;
    Mesh_Primitive primitive;

    Vertex_Attrib_Type[] attributes;

    void[..]   vertices;
    uint32[..] indices;

    uint32 gl_handle;
    uint32 vertex_buffer_id;
    uint32 index_buffer_id;

    bool resync;
}

void mesh_ensure_vao(Mesh* mesh) {
    if mesh.vao  return;

    VAO* vao = get_vao(vertex3D_attribs, mesh.primitive);

    list_add(*vao.meshes, *mesh);
    mesh.vao = vao;
    mesh.vao_index_start = list_length(vao.indices);
    mesh.vao_index_count = list_length(mesh.indices);
    mesh.vao_vertex_base = list_length(vao.vertices);

    for 0 .. list_length(mesh.vertices)   list_add(*vao.vertices, *mesh.vertices[it]);
    for 0 .. list_length(mesh.indices)    list_add(*vao.indices,  *mesh.indices[it]);

    vao.resync = true;
}

VAO* get_vao(Vertex_Attrib_Type[] attributes, Mesh_Primitive primitive) {
    static VAO*[..] vaos = list_create(sizeof VAO*);

    for 0 .. list_length(vaos) {
        VAO* vao = vaos[it];
        if vao.attributes.data == attributes.data
        if vao.attributes.length == attributes.length
        if vao.primitive == primitive
            return vao;
    }

    VAO* vao = malloc(sizeof VAO);
    list_add(*vaos, *vao);
    @vao = {};

    vao.meshes = list_create(sizeof Mesh*);

    vao.attributes = attributes;
    vao.primitive  = primitive;

    vao.vertices = list_create(vertex_bytesize(attributes));
    vao.indices  = list_create(sizeof uint32);

    vao.vertex_buffer_id  = ogl_buffer_generate();
    vao.index_buffer_id   = ogl_buffer_generate();

    string label = {};
    vao.gl_handle = make_vao(
        label,
        vao.vertex_buffer_id,
        vao.index_buffer_id,
        vao.attributes);

    vao.resync = true;

    return vao;
}

void vao_sync(VAO* vao) {
    print("[PERFORMANCE]: vao:", vao.gl_handle, " resync\n");

    ogl_buffer_init(vao.vertex_buffer_id, vao.vertices);
    ogl_buffer_init(vao.index_buffer_id,  vao.indices);

    vao.resync = false;
}

uint32 make_vao(string label, uint32 vbo, ebo, Vertex_Attrib_Type[] attribs) {
    Vertex_Attrib_Type[] per_instance_attribs = {};
    return make_vao(label, vbo, ebo, 0, attribs, per_instance_attribs);
}

uint32 make_vao(string label, uint32 vbo, ebo, instance_buffer, Vertex_Attrib_Type[] attribs, per_instance_attribs) {
    uint32 vao = 0;

    glGenVertexArrays(1, *vao);
    glBindVertexArray(vao);

    if label.chars {
        glObjectLabel(GL_VERTEX_ARRAY, vao, label.length, label.chars);
    }

    glBindBuffer(GL_ARRAY_BUFFER,         vbo);
    glBindBuffer(GL_ELEMENT_ARRAY_BUFFER, ebo);

    uint32 bytesize = vertex_bytesize(attribs);
    init_vertex_layout(bytesize as int32, attribs);

    if instance_buffer and per_instance_attribs.length != 0 {
        glBindBuffer(GL_ARRAY_BUFFER, instance_buffer);
        uint32 base_index = attribs.length;
        uint32 divisor = 1;
        init_vertex_layout(base_index, divisor, vertex_bytesize(per_instance_attribs) as int32, per_instance_attribs);
    }

    glBindVertexArray(0);
    glBindBuffer(GL_ARRAY_BUFFER, 0);

    return vao;
}

